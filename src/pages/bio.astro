---
// Gerado a partir de: bio.html
import { Fragment } from 'astro/jsx-runtime';
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import Img from '../components/ui/Img.astro';
import LeadForm from '../components/forms/LeadForm.astro';
import '../styles/bio.css';
---

<Base
  title="BIO — Naturalle Eventos"
  ogImage="/images/og-default.jpg"
  canonical="https://eventos.naturalleeventos.com/bio/"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://npmcdn.com/flatpickr/dist/flatpickr.min.css" />
    <script is:inline src="https://npmcdn.com/flatpickr/dist/flatpickr.min.js"></script>
  </Fragment>

  <main class="bio-container">
    <!-- Cabeçalho (Hero/Logo) -->
    <header class="bio-header">
      <div class="bio-header-inner">
        <div class="logo-wrapper">
          <Img src="LOGO-BRANCA-1.avif" alt="Naturalle Eventos" width={1230} height={497} class="logo" priority />
        </div>
      </div>
    </header>

    <!-- Seção de Conteúdo e Formulário -->
    <section class="bio-content-section" id="contato">
      <div class="bio-content-inner">
        <h1 class="main-title">O espaço que inspira sonhos.</h1>
        
        <div class="form-container">
          <h2 class="form-title">Venha realizar a sua celebração no Naturalle.</h2>
          <div class="form-divider">
            <span class="divider-line"></span>
          </div>
          
          <LeadForm
            formId="lead-form"
            project={config.project_slug}
            submitUrl={config.forms['lead-form'].webhooks[0]}
            redirectUrl={config.forms['lead-form'].redirect_on_success}
            submitText="ENVIAR SOLICITAÇÃO"
            honeypot
            fields={[
              { name: 'nome', type: 'text', placeholder: 'Nome', required: true },
              {
                type: 'row',
                fields: [
                  { name: 'telefone', type: 'text', placeholder: 'WhatsApp', required: true },
                  { name: 'email', type: 'email', placeholder: 'E-mail', required: true }
                ]
              },
              { name: 'tipo', type: 'select', placeholder: '', required: true, options: [
                { value: '', label: 'Tipo de evento:' },
                { value: 'Aniversário', label: 'Aniversário' },
                { value: 'Aniversário debutante', label: 'Aniversário debutante' },
                { value: 'Bodas', label: 'Bodas' },
                { value: 'Casamento', label: 'Casamento' },
                { value: 'Confraternização corporativa', label: 'Confraternização corporativa' },
                { value: 'Confraternização social', label: 'Confraternização social' },
                { value: 'Corporativo', label: 'Corporativo' },
                { value: 'Feiras e Exposições', label: 'Feiras e Exposições' },
                { value: 'Formatura', label: 'Formatura' },
                { value: 'Happy Hours', label: 'Happy Hours' },
                { value: 'Masterclass e Palestras', label: 'Masterclass e Palestras' },
                { value: 'Mentorias e Treinamentos', label: 'Mentorias e Treinamentos' },
                { value: 'Offsite corporativo', label: 'Offsite corporativo' },
                { value: 'Reuniões de Networking', label: 'Reuniões de Networking' },
                { value: 'Shows e Festivais', label: 'Shows e Festivais' },
                { value: 'Workshops, Conferências e Seminários', label: 'Workshops, Conferências e Seminários' },
                { value: 'Outros', label: 'Outros' }
              ] },
              { name: 'data', type: 'text', placeholder: 'Data do Evento', required: true },
              { name: 'convidados', type: 'number', placeholder: 'N° de Pessoas', required: true },
              { name: 'mensagem', type: 'textarea', placeholder: 'Detalhes adicionais: (Não obrigatório)', required: false }
            ]}
          />
        </div>
      </div>
    </section>

    <!-- Rodapé -->
    <footer class="bio-footer">
      <div class="bio-footer-inner">
        <div class="footer-copyright">
          <p>© 2026 – Naturalle Eventos – Todos os direitos reservados.</p>
        </div>
        
        <div class="footer-logo">
          <Img src="LOGO-BRANCA-1.avif" alt="Naturalle Eventos" width={1230} height={497} class="footer-logo-img" />
        </div>
        
        <div class="footer-credit">
          <span>Desenvolvido por:</span>
          <a href="http://dmove.com.br" target="_blank" rel="noopener noreferrer" class="credit-link">
            <Img src="Versao-Principal-Negativo-scaled-e1750426923582.avif" alt="Dmove" width={1882} height={474} class="credit-logo" />
          </a>
        </div>
      </div>
    </footer>
  </main>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const initFlatpickr = () => {
        const dataInput = document.querySelector('input[name="data"]');
        if (dataInput && window.flatpickr && !dataInput._flatpickr) {
          window.flatpickr(dataInput, {
            disableMobile: true,
            dateFormat: 'd/m/Y',
            locale: {
              weekdays: {
                shorthand: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'],
                longhand:  ['Domingo', 'Segunda-feira', 'Terça-feira', 'Quarta-feira', 'Quinta-feira', 'Sexta-feira', 'Sábado'],
              },
              months: {
                shorthand: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                longhand:  ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
              },
              firstDayOfWeek: 1,
              ordinal: () => 'º',
            }
          });
        }
      };

      initFlatpickr();

      const disableSpellcheck = () => {
        document.querySelectorAll('input, textarea').forEach(el => {
          el.setAttribute('spellcheck', 'false');
          el.setAttribute('autocomplete', 'off');
        });
      };
      disableSpellcheck();

      // Observador para remontar se houver mutações (ex: carregamento dinâmico ou alterações no DOM)
      const observer = new MutationObserver(() => {
        initFlatpickr();
        disableSpellcheck();
      });
      observer.observe(document.body, { childList: true, subtree: true });
    });
  </script>
</Base>
