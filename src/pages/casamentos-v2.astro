---
// Gerado a partir de: casamentos-v2.html e refatorado semanticamente
import { Fragment } from 'astro/jsx-runtime';
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import Img from '../components/ui/Img.astro';
import LeadForm from '../components/forms/LeadForm.astro';
import '../styles/casamentos-v2.css';
---

<Base
  title="Casamentos ao Ar Livre em Goiânia — Naturalle Eventos"
  ogImage="/images/og-casamentos-v2.jpg"
  canonical="https://eventos.naturalleeventos.com/casamentos-v2/"
>
  <Fragment slot="head">
    <!-- Icon Fonts CDNs -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@icon/themify-icons/themify-icons.css" />
    <link rel="stylesheet" href="https://cdn.linearicons.com/free/1.0.0/icon-font.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@mdi/font@7.4.47/css/materialdesignicons.min.css" />
    <link rel="stylesheet" href="https://maxst.icons8.com/vue-static/landings/line-awesome/line-awesome/1.3.0/css/line-awesome.min.css" />
    
    <!-- Flatpickr CSS CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <!-- Flatpickr Script CDNs -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/pt.js"></script>
  </Fragment>

  <main class="casamentos-container">
    <!-- Seção 1: Hero / Header -->
    <header class="casamentos-hero">
      <div class="hero-inner">
        <div class="logo-wrapper">
          <Img src="LOGO-BRANCA-1024x414.avif" alt="Naturalle Eventos" width={800} height={323} class="logo" priority />
        </div>
        <div class="hero-content">
          <span class="hero-subtitle">Espaço de eventos em Goiânia</span>
          <h1 class="hero-title">Aqui, seu casamento ao ar livre se torna uma experiência completa e inesquecível.</h1>
          <p class="hero-desc">Espaço, gastronomia e estrutura pronta para você viver seu grande dia sem preocupações.</p>
          <a href="#contato" class="hero-btn">Solicite um orçamento</a>
        </div>
      </div>
    </header>

    <!-- Seção 2: Conceito -->
    <section class="casamentos-concept">
      <div class="concept-inner">
        <h2 class="concept-title">Seu grande dia já <br class="mobile-only" />nasce pronto <span class="accent-text">para ser vivido</span></h2>
        <p class="concept-desc">Em meio à natureza, o Naturalle reúne ambiente, buffet e organização em uma única experiência. Tudo é planejado para que você não precise se preocupar com fornecedores ou etapas separadas.</p>
      </div>
    </section>

    <!-- Seção 3: Spacer Decorativo -->
    <div class="casamentos-spacer-section"></div>

    <!-- Seção 4: Galeria Jardim (Marquee) -->
    <section class="casamentos-gallery-section">
      <div class="gallery-header">
        <h2 class="gallery-title">em nosso jardim seu <span class="accent-text">sonho ganha vida</span></h2>
        <p class="gallery-desc">Área externa ampla, perfeita para tornar sua cerimônia ainda mais especial e integrada aos outros momentos do evento.</p>
      </div>
      <div class="gsap-marquee-container carousel-jardim">
        <div class="gsap-marquee-wrapper">
          <div class="gsap-marquee-slide"><Img src="PTF-5-scaled.avif" alt="Jardim Naturalle" width={600} height={600} /></div>
          <div class="gsap-marquee-slide"><Img src="PTF-11-scaled.avif" alt="Jardim Naturalle" width={600} height={600} /></div>
          <div class="gsap-marquee-slide"><Img src="PTF-174-scaled-e1767883080394.avif" alt="Jardim Naturalle" width={600} height={600} /></div>
          <div class="gsap-marquee-slide"><Img src="PTF-7-scaled.avif" alt="Jardim Naturalle" width={600} height={600} /></div>
          <div class="gsap-marquee-slide"><Img src="PTF-131-scaled.avif" alt="Jardim Naturalle" width={600} height={600} /></div>
        </div>
      </div>
    </section>

    <!-- Seção 5: Galeria Recepção (Marquee) -->
    <section class="casamentos-gallery-section">
      <div class="gallery-header">
        <h2 class="gallery-title">Celebração e recepção <span class="accent-text">no mesmo lugar</span></h2>
        <p class="gallery-desc">Após a cerimônia, seus convidados seguem para um espaço aconchegante, ideal para receber até 200 convidados.</p>
      </div>
      <div class="gsap-marquee-container carousel-recepcao">
        <div class="gsap-marquee-wrapper">
          <div class="gsap-marquee-slide"><Img src="PTF-38-scaled.avif" alt="Recepção Naturalle" width={600} height={600} /></div>
          <div class="gsap-marquee-slide"><Img src="PTF-49-scaled.avif" alt="Recepção Naturalle" width={600} height={600} /></div>
          <div class="gsap-marquee-slide"><Img src="PTF-3-scaled.avif" alt="Recepção Naturalle" width={600} height={600} /></div>
          <div class="gsap-marquee-slide"><Img src="PTF-47-scaled.avif" alt="Recepção Naturalle" width={600} height={600} /></div>
          <div class="gsap-marquee-slide"><Img src="PTF-50-scaled.avif" alt="Recepção Naturalle" width={600} height={600} /></div>
        </div>
      </div>
    </section>

    <!-- Seção 6: Galeria Gastronomia (Marquee) -->
    <section class="casamentos-gallery-section">
      <div class="gallery-header">
        <h2 class="gallery-title">Gastronomia <span class="accent-text">personalizada</span></h2>
        <p class="gallery-desc">Sabores e combinações pensados especialmente para o seu evento.</p>
      </div>
      <div class="gsap-marquee-container carousel-gastronomia">
        <div class="gsap-marquee-wrapper">
          <div class="gsap-marquee-slide"><Img src="Naturelle-Eventos-Casamento-03.06.2023-29-1_resultado.avif" alt="Gastronomia" width={600} height={600} /></div>
          <div class="gsap-marquee-slide"><Img src="IMG-20251110-WA0434_resultado.avif" alt="Gastronomia" width={600} height={600} /></div>
          <div class="gsap-marquee-slide"><Img src="IMG-20251110-WA0436_resultado.avif" alt="Gastronomia" width={600} height={600} /></div>
          <div class="gsap-marquee-slide"><Img src="IMG-20251110-WA0437_resultado.avif" alt="Gastronomia" width={600} height={600} /></div>
          <div class="gsap-marquee-slide"><Img src="TA4_8280_resultado.avif" alt="Gastronomia" width={600} height={600} /></div>
          <div class="gsap-marquee-slide"><Img src="TAT_6437_resultado.avif" alt="Gastronomia" width={600} height={600} /></div>
        </div>
      </div>
    </section>

    <!-- Seção 7: Diferenciais -->
    <section class="casamentos-features-section">
      <div class="features-header">
        <h2 class="features-title">Tudo o que seu <br class="mobile-only" />casamento precisa, <span class="accent-text">em um só lugar</span></h2>
        <p class="features-desc">Além da estrutura completa e do buffet próprio, cuidamos de cada detalhe da sua experiência.</p>
      </div>
      <div class="features-grid">
        <div class="feature-item">
          <div class="feature-icon-wrapper">
            <i class="ti-location-pin"></i>
          </div>
          <h3 class="feature-item-title">Localização Privilegiada</h3>
        </div>
        <div class="feature-item">
          <div class="feature-icon-wrapper">
            <i class="lnr lnr-car"></i>
          </div>
          <h3 class="feature-item-title">Estacionamento</h3>
        </div>
        <div class="feature-item">
          <div class="feature-icon-wrapper">
            <i class="lnr lnr-dinner"></i>
          </div>
          <h3 class="feature-item-title">Cozinha Industrial</h3>
        </div>
        <div class="feature-item">
          <div class="feature-icon-wrapper">
            <i class="mdi mdi-star-circle-outline"></i>
          </div>
          <h3 class="feature-item-title">Exclusividade (1 evento por dia)</h3>
        </div>
        <div class="feature-item">
          <div class="feature-icon-wrapper">
            <i class="mdi mdi-table-chair"></i>
          </div>
          <h3 class="feature-item-title">Mobiliário Próprio</h3>
        </div>
        <div class="feature-item">
          <div class="feature-icon-wrapper">
            <i class="las la-people-carry"></i>
          </div>
          <h3 class="feature-item-title">Equipe Operacional</h3>
        </div>
      </div>
    </section>

    <!-- Seção 8: Testimonials collage -->
    <section class="casamentos-testimonials-section">
      <div class="testimonials-header">
        <h2 class="testimonials-title">Agora é a sua vez <span class="accent-text">de viver essa experiência</span></h2>
        <p class="testimonials-desc">Veja os momentos inesquecíveis realizados no Naturalle.</p>
      </div>
      <div class="testimonials-gallery">
        <div class="gallery-row">
          <div class="gallery-item" style="--grow: 0.936;"><Img src="TAT_6473-2-scaled.avif" alt="Casamento no Naturalle" width={600} height={600} /></div>
          <div class="gallery-item" style="--grow: 0.667;"><Img src="PTF-67-scaled.avif" alt="Momentos da celebração" width={600} height={600} /></div>
          <div class="gallery-item" style="--grow: 1.500;"><Img src="PTF-55-scaled.avif" alt="Decoração da festa" width={600} height={600} /></div>
        </div>
        <div class="gallery-row">
          <div class="gallery-item" style="--grow: 0.667;"><Img src="PTF-188-scaled.avif" alt="Noivos no altar" width={600} height={600} /></div>
          <div class="gallery-item" style="--grow: 1.500;"><Img src="Casamento-Bruna-e-Junior-24-09-22-88.avif" alt="Cerimônia ao ar livre" width={600} height={600} /></div>
          <div class="gallery-item" style="--grow: 0.667;"><Img src="PTF-173-scaled.avif" alt="Brinde dos noivos" width={600} height={600} /></div>
        </div>
        <div class="gallery-row">
          <div class="gallery-item" style="--grow: 0.667;"><Img src="PTF-370-scaled.avif" alt="Pista de dança decorada" width={600} height={600} /></div>
          <div class="gallery-item" style="--grow: 1.500;"><Img src="Casamento-Bruna-e-Junior-24-09-22-260.avif" alt="Retrato dos noivos" width={600} height={600} /></div>
        </div>
        <div class="gallery-row">
          <div class="gallery-item" style="--grow: 1.500;"><Img src="PTF-150-scaled.avif" alt="Decoração de casamento à noite" width={600} height={600} /></div>
          <div class="gallery-item" style="--grow: 0.667;"><Img src="Naturelle-Eventos-Casamento-03.06.2023-19-scaled.avif" alt="Entrada dos noivos" width={600} height={600} /></div>
          <div class="gallery-item" style="--grow: 0.667;"><Img src="Naturelle-Eventos-Casamento-03.06.2023-9-scaled.avif" alt="Cerimônia sob as luzes" width={600} height={600} /></div>
        </div>
      </div>
    </section>

    <!-- Seção 9: Contato (Contact Form) -->
    <section class="casamentos-contact-section" id="contato">
      <div class="contact-container">
        <div class="contact-info">
          <h2 class="contact-title">Realize seu sonho no espaço de eventos mais completo de Goiânia!</h2>
          <p class="contact-desc">Basta preencher o formulário que entraremos em contato com você para apresentar as melhores opções para o seu grande dia.</p>
        </div>
        <div class="contact-form-card">
          <h3 class="form-title">Preencha seus dados e receba um orçamento personalizado.</h3>
          <LeadForm
            formId="lead-form"
            project={config.project_slug}
            submitUrl={config.forms['lead-form'].webhooks[0]}
            redirectUrl={config.forms['lead-form'].redirect_on_success}
            submitText="ENVIAR SOLICITAÇÃO"
            honeypot
            fields={[
              { name: 'form_fields[nome]', type: 'text', placeholder: 'Nome', required: true },
              { name: 'form_fields[telefone]', type: 'text', placeholder: 'WhatsApp', required: true },
              { name: 'form_fields[email]', type: 'email', placeholder: 'E-mail', required: true },
              { name: 'form_fields[data]', type: 'text', placeholder: 'Data do Evento', required: true },
              { name: 'form_fields[convidados]', type: 'number', placeholder: 'N° de Pessoas', required: true },
              { name: 'form_fields[mensagem]', type: 'textarea', placeholder: 'Detalhes adicionais: (Não obrigatório)', required: false },
              { name: 'form_fields[tipo]', type: 'select', placeholder: '', required: true, options: [
                { value: '', label: 'Tipo de evento' },
                { value: 'Bodas', label: 'Bodas' },
                { value: 'Casamento', label: 'Casamento' },
                { value: 'Confraternização social', label: 'Confraternização social' },
                { value: 'Outros', label: 'Outros' }
              ] }
            ]}
          />
        </div>
      </div>
    </section>

    <!-- Seção 10: Rodapé (Footer) -->
    <footer class="casamentos-footer">
      <div class="footer-container">
        <div class="footer-copy">
          <p>© 2026 - Naturalle Eventos - Todos os direitos reservados.</p>
        </div>
        <div class="footer-logos">
          <Img src="LOGO-BRANCA.avif" alt="Naturalle Eventos" width={200} height={81} class="footer-logo-main" />
          <a href="http://dmove.com.br" target="_blank" rel="noopener noreferrer" class="footer-developer">
            <span>Desenvolvido por:</span>
            <Img src="Versao-Principal-Negativo-scaled-e1750426923582.avif" alt="Dmove" width={100} height={25} class="footer-logo-dev" />
          </a>
        </div>
      </div>
    </footer>
  </main>
</Base>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    // Inicialização do Flatpickr
    if (window.flatpickr) {
      window.flatpickr('input[name="form_fields[data]"]', {
        dateFormat: 'd/m/Y',
        locale: 'pt',
        disableMobile: true
      });
    }

    // Marquees GSAP
    const containers = document.querySelectorAll('.gsap-marquee-container');
    containers.forEach(container => {
      const wrapper = container.querySelector('.gsap-marquee-wrapper');
      if (!wrapper) return;

      // Clona as imagens duas vezes para garantir loop contínuo perfeito
      const slides = Array.from(wrapper.children);
      slides.forEach(slide => {
        wrapper.appendChild(slide.cloneNode(true));
      });
      slides.forEach(slide => {
        wrapper.appendChild(slide.cloneNode(true));
      });

      let marqueeTween;

      const startMarquee = () => {
        const totalWidth = wrapper.scrollWidth / 3;

        if (marqueeTween) {
          marqueeTween.kill();
        }

        marqueeTween = gsap.to(wrapper, {
          x: -totalWidth,
          duration: totalWidth / 45,
          ease: 'none',
          repeat: -1
        });
      };

      startMarquee();

      container.addEventListener('mouseenter', () => marqueeTween && marqueeTween.pause());
      container.addEventListener('mouseleave', () => marqueeTween && marqueeTween.resume());

      // Resize handler
      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => {
          startMarquee();
        }, 150);
      });

      // Expõe tweens globalmente para permitir controle pelo VRT se necessário
      window._marqueeTweens = window._marqueeTweens || [];
      window._marqueeTweens.push(marqueeTween);
    });
  });
</script>
