---
import Base from '../layouts/Base.astro';
import LeadForm from '../components/forms/LeadForm.astro';
import config from '../../config.json';

// Descomente conforme necessário:
// import Img from '../components/ui/Img.astro';
// import Video from '../components/ui/Video.astro';
// import StaticMap from '../components/ui/StaticMap.astro';
// import '../styles/index.css';
---

<Base
  title={`${config.project_name} | Título da página`}
  description="Descrição da página para SEO."
  ogImage="/images/og-default.jpg"
  canonical="https://dominio.com.br/"
>

  <!-- Cole o conteúdo migrado do Elementor aqui -->
  <!-- Dica: use npm run scaffold para gerar automaticamente a partir de _html-originais/ -->

  <section style="min-height:100vh;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:2rem;text-align:center;padding:2rem;">
    <h1>{config.project_name}</h1>
    <p>Template pronto. Cole o HTML migrado do Elementor ou use <code>npm run scaffold</code>.</p>

    <LeadForm
      formId="lead-form"
      project={config.project_slug}
      submitUrl={config.forms['lead-form'].webhooks[0]}
      redirectUrl={config.forms['lead-form'].redirect_on_success}
      submitText="Enviar"
      honeypot
    />
  </section>

</Base>
