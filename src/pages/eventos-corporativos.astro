    <!-- Seção 9: Contato (Contact Form) -->
    <section class="corporativos-contact-section" id="contato">
      <div class="contact-container">
        <div class="contact-info">
          <h2 class="contact-title">Pronto para começar a planejar o seu evento corporativo?</h2>
          <p class="contact-desc">Basta preencher o formulário que entraremos em contato com você.</p>
        </div>
        <div class="contact-form-card">
          <h3 class="form-title">Preencha seus dados e receba um orçamento personalizado.</h3>
          <LeadForm
            formId="form_corporativo"
            project={config.project_slug}
            submitUrl={config.forms['lead-form'].webhooks[0]}
            redirectUrl={config.forms['lead-form'].redirect_on_success}
            submitText="ENVIAR SOLICITAÇÃO"
            honeypot
            fields={[
              { name: 'Nome', type: 'text', placeholder: 'Nome', required: true },
              {
                type: 'row',
                fields: [
                  { name: 'WhatsApp', type: 'text', placeholder: 'WhatsApp', required: true },
                  { name: 'E-mail', type: 'email', placeholder: 'E-mail', required: true }
                ]
              },
              { name: 'Tipo de evento', type: 'select', placeholder: '', required: true, options: [
                { value: '', label: 'Tipo de evento' },
                { value: 'Confraternização corporativa', label: 'Confraternização corporativa' },
                { value: 'Corporativo', label: 'Corporativo' },
                { value: 'Feiras e Exposições', label: 'Feiras e Exposições' },
                { value: 'Happy Hours', label: 'Happy Hours' },
                { value: 'Masterclass e Palestras', label: 'Masterclass e Palestras' },
                { value: 'Mentorias e Treinamentos', label: 'Mentorias e Treinamentos' },
                { value: 'Offsite corporativo', label: 'Offsite corporativo' },
                { value: 'Reuniões de Networking', label: 'Reuniões de Networking' },
                { value: 'Shows e Festivais', label: 'Shows e Festivais' },
                { value: 'Workshops, Conferências e Seminários', label: 'Workshops, Conferências e Seminários' },
                { value: 'Outros', label: 'Outros' }
              ] },
              { name: 'Data do evento', type: 'text', placeholder: 'Data do Evento', required: true },
              { name: 'Convidados', type: 'number', placeholder: 'N° de Pessoas', required: true },
              { name: 'Mensagem', type: 'textarea', placeholder: 'Detalhes adicionais: (Não obrigatório)', required: false },
              { name: 'Fonte', type: 'hidden', value: 'Landing page/corporativo' }
            ]}
          />
        </div>
      </div>
    </section>

    <!-- Seção 10: Rodapé (Footer) -->
    <footer class="corporativos-footer">
      <div class="footer-container">
        <div class="footer-copy">
          <p>© 2026 - Naturalle Eventos - Todos os direitos reservados</p>
        </div>
        <div class="footer-logo-center">
          <Img src="LOGO-BRANCA.avif" alt="Naturalle Eventos" width={200} height={81} class="footer-logo-main" />
        </div>
        <div class="footer-developer-wrapper">
          <a href="http://dmove.com.br" target="_blank" rel="noopener noreferrer" class="footer-developer">
            <span>Desenvolvido por</span>
            <Img src="Versao-Principal-Negativo-scaled-e1750426923582.avif" alt="Dmove" width={100} height={25} class="footer-logo-dev" />
          </a>
        </div>
      </div>
    </footer>
  </main>
</Base>
<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    // Inicialização do Flatpickr
    const initFlatpickr = () => {
      const dataInput = document.querySelector('input[name="Data do evento"]');
      if (dataInput && window.flatpickr && !dataInput._flatpickr) {
        window.flatpickr(dataInput, {
          dateFormat: 'd/m/Y',
          locale: 'pt',
          disableMobile: true
        });
      }
    };

    const initPhoneMask = () => {
      const phoneInput = document.querySelector('input[name="WhatsApp"]');
      if (phoneInput) {
        phoneInput.addEventListener('input', (e) => {
          let value = (e.target as HTMLInputElement).value.replace(/\D/g, '');
          if (value.length > 11) value = value.slice(0, 11);

          if (value.length > 10) {
            value = value.replace(/^(\d{2})(\d{5})(\d{4}).*/, '($1) $2-$3');
          } else if (value.length > 6) {
            value = value.replace(/^(\d{2})(\d{4})(\d{0,4}).*/, '($1) $2-$3');
          } else if (value.length > 2) {
            value = value.replace(/^(\d{2})(\d{0,5})/, '($1) $2');
          } else if (value.length > 0) {
            value = value.replace(/^(\d*)/, '($1');
          }
          (e.target as HTMLInputElement).value = value;
        });
      }
    };

    initFlatpickr();
    initPhoneMask();

    // Marquees GSAP (Apenas no Mobile - construídos dinamicamente)
    const initMobileMarquees = () => {
      if (window.innerWidth >= 768) return;

      const grids = document.querySelectorAll('.salao-photo-grid, .gastronomia-photo-grid');
      
      grids.forEach(grid => {
        // Se já foi inicializado, não faz nada
        if (grid._isInitialized) return;

        grid._isInitialized = true;
        grid._originalHTML = grid.innerHTML;

        // Adiciona classe de container
        grid.classList.add('gsap-marquee-container');

        // Cria o wrapper flexível
        const wrapper = document.createElement('div');
        wrapper.className = 'gsap-marquee-wrapper';

        // Move os itens originais para dentro do wrapper
        while (grid.firstChild) {
          wrapper.appendChild(grid.firstChild);
        }
        grid.appendChild(wrapper);

        // Clona os slides duas vezes para o loop contínuo
        const slides = Array.from(wrapper.children);
        slides.forEach(slide => {
          wrapper.appendChild(slide.cloneNode(true));
        });
        slides.forEach(slide => {
          wrapper.appendChild(slide.cloneNode(true));
        });

        let marqueeTween;

        const startMarquee = () => {
          if (window.innerWidth >= 768) {
            if (marqueeTween) marqueeTween.kill();
            return;
          }

          const totalWidth = wrapper.scrollWidth / 3;

          if (marqueeTween) {
            marqueeTween.kill();
          }

          marqueeTween = gsap.to(wrapper, {
            x: -totalWidth,
            duration: totalWidth / 45,
            ease: 'none',
            repeat: -1
          });
          grid._marqueeTween = marqueeTween;
        };

        startMarquee();

        // Pausa no hover (se houver mouse)
        grid.addEventListener('mouseenter', () => {
          if (window.innerWidth < 768 && grid._marqueeTween) {
            grid._marqueeTween.pause();
          }
        });
        grid.addEventListener('mouseleave', () => {
          if (window.innerWidth < 768 && grid._marqueeTween) {
            grid._marqueeTween.resume();
          }
        });

        // Eventos de toque para pausar
        grid.addEventListener('touchstart', () => {
          if (grid._marqueeTween) grid._marqueeTween.pause();
        });
        grid.addEventListener('touchend', () => {
          if (grid._marqueeTween) grid._marqueeTween.resume();
        });
      });
    };

    // Destroi os marquees e restaura HTML original no desktop
    const destroyMarquees = () => {
      const grids = document.querySelectorAll('.salao-photo-grid, .gastronomia-photo-grid');
      grids.forEach(grid => {
        if (!grid._isInitialized) return;

        if (grid._marqueeTween) {
          grid._marqueeTween.kill();
          grid._marqueeTween = null;
        }

        if (grid._originalHTML) {
          grid.innerHTML = grid._originalHTML;
        }
        grid.classList.remove('gsap-marquee-container');
        grid._isInitialized = false;
      });
    };

    const handleResize = () => {
      if (window.innerWidth < 768) {
        initMobileMarquees();
      } else {
        destroyMarquees();
      }
    };

    // Inicializa se for mobile
    if (window.innerWidth < 768) {
      initMobileMarquees();
    }

    // Listener de resize
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(handleResize, 200);
    });
  });
</script>
