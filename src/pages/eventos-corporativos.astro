    <!-- Seção 7: Salão Rústico -->
    <section class="corporativos-salao-section" id="salao-rustico">
      <div class="salao-header">
        <h2 class="salao-title">Salão rústico</h2>
        <p class="salao-desc">Espaço com layout adaptável para receber até 200 pessoas.</p>
      </div>
      <div class="salao-photo-grid">
        <div class="photo-item"><Img src="IMG-20251106-WA0056-1.avif" alt="Salão Rústico Naturalle" width={600} height={1067} /></div>
        <div class="photo-item"><Img src="TA4_8194-scaled.avif" alt="Salão Rústico Naturalle" width={600} height={1067} /></div>
        <div class="photo-item"><Img src="IMG-20251114-WA0031.avif" alt="Salão Rústico Naturalle" width={600} height={1067} /></div>
        <div class="photo-item"><Img src="TAT_4954-scaled.avif" alt="Salão Rústico Naturalle" width={600} height={1067} /></div>
        <div class="photo-item"><Img src="55164358936_69c54705d5_o_resultado.avif" alt="Salão Rústico Naturalle" width={600} height={1067} /></div>
        <div class="photo-item"><Img src="55164521228_39e7846ed0_o_resultado.avif" alt="Salão Rústico Naturalle" width={600} height={1067} /></div>
      </div>
