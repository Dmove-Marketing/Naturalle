    <!-- Seção 7: Gastronomia personalizada -->
    <section class="corporativos-gastronomia-section" id="gastronomia">
      <div class="gastronomia-header">
        <h2 class="gastronomia-title">Gastronomia <span class="accent-text">personalizada</span></h2>
        <p class="gastronomia-desc">Sabores e combinações pensados especialmente para o seu evento.</p>
      </div>
      <div class="gastronomia-photo-grid">
        <div class="photo-item"><Img src="55163457952_f70b500692_o_resultado.avif" alt="Gastronomia Naturalle" width={600} height={1067} /></div>
        <div class="photo-item"><Img src="55164356621_5b2d8cf7dd_o_resultado.avif" alt="Gastronomia Naturalle" width={600} height={1067} /></div>
        <div class="photo-item"><Img src="55164736830_c8f2a025f1_o_resultado.avif" alt="Gastronomia Naturalle" width={600} height={1067} /></div>
        <div class="photo-item"><Img src="55163457902_ce3b74da89_o_resultado.avif" alt="Gastronomia Naturalle" width={600} height={1067} /></div>
      </div>
    </section>

    <!-- Seção 8: Diferenciais -->
    <section class="corporativos-diferenciais-section" id="diferenciais">
      <div class="diferenciais-header">
        <h2 class="diferenciais-title">Diferenciais que você <span class="accent-text">encontra aqui</span></h2>
        <p class="diferenciais-desc">Cuidamos de tudo para que seus convidados se sintam bem do início ao fim.</p>
