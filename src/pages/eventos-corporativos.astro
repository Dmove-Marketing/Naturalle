<Base
  title="Eventos Corporativos — Naturalle Eventos"
  description="O espaço ideal para eventos corporativos em Goiânia. Una pessoas, ideias e experiências em um ambiente versátil e integrado à natureza."
  ogImage="/images/og-eventos-corporativos.jpg"
  canonical="https://eventos.naturalleeventos.com/eventos-corporativos/"
>
  <Fragment slot="head">
    <!-- Icon Fonts CDNs (Carregamento assíncrono para melhorar performance) -->
    <link rel="stylesheet" href="https://maxst.icons8.com/vue-static/landings/line-awesome/line-awesome/1.3.0/css/line-awesome.min.css" media="print" onload="this.media='all'" />
